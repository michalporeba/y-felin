@prefix mlg: <https://michalporeba.com/ns/lifegraph#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix dct: <http://purl.org/dc/terms/> .

<https://michalporeba.com/ns/lifegraph>
  a owl:Ontology ;
  rdfs:label "LifeGraph ontology"@en ;
  rdfs:comment "Core ontology for personal local-first applications."@en .

mlg:JournalEntry
  a owl:Class ;
  rdfs:label "Journal entry"@en ;
  rdfs:comment "A journal-style entry in a personal local-first application."@en .

mlg:Task
  a owl:Class ;
  rdfs:label "Task"@en ;
  rdfs:comment "A task journal entry."@en ;
  rdfs:subClassOf mlg:JournalEntry .

mlg:Note
  a owl:Class ;
  rdfs:label "Note"@en ;
  rdfs:comment "A note journal entry."@en ;
  rdfs:subClassOf mlg:JournalEntry .

dct:title
  rdfs:label "title"@en .
